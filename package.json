{
  "name": "hero-assistant",
  "version": "1.0.0",
  "description": "HERO voice-first AI assistant core",
  "main": "dist/cli.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx src/server.ts",
    "dev:ui": "npm run dev --prefix frontend",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "build": "tsc",
    "start": "node dist/cli.js",
    "start:server": "node dist/server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "concurrently": "^8.2.2"
  }
}
